#!/bin/bash
if ! tmux ls 2>/dev/null | grep -q .; then
  tmux new-session
fi

options=("New session" "Open existing")
selected=0
count=${#options[@]}

draw_menu() {
  for i in "${!options[@]}"; do
    tput el
    if [ "$i" -eq "$selected" ]; then
      printf "  \e[1;34m> ${options[$i]}\e[0m\r\n"
    else
      printf "    ${options[$i]}\r\n"
    fi
  done
  tput cuu "$count"
}

tput civis
echo ""
draw_menu

while true; do
  IFS= read -rsn1 key
  if [ "$key" = $'\e' ]; then
    IFS= read -rsn2 key
    case "$key" in
    '[A') key='k' ;;
    '[B') key='j' ;;
    esac
  fi
  case "$key" in
  j) selected=$(((selected + 1) % count)) ;;
  k) selected=$(((selected - 1 + count) % count)) ;;
  '') break ;;
  q)
    tput cnorm
    tput cud "$count"
    echo ""
    exit
    ;;
  esac
  draw_menu
done

tput cnorm
tput cud "$count"
echo ""

case "$selected" in
0) exec tmux new-session ;;
1) exec tmux attach-session \; choose-tree -Zw ;;
esac
